generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum VideoStatus {
  PENDING
  GENERATING
  COMPLETED
  FAILED
}

model Product {
  id          String      @id @default(uuid())
  title       String
  price       String
  salesCount  Int
  productUrl  String      @unique
  imageUrl    String
  description String
  aiScript    String?
  videoUrl    String?
  renderJobId String?
  videoProgress Int       @default(0)
  videoError   String?
  webhookUrl  String?
  videoStatus VideoStatus @default(PENDING)
  createdAt   DateTime    @default(now())
}
